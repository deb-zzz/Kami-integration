{
	"name": "kami721-contracts",
	"version": "1.0.0",
	"description": "KAMI721 smart contracts suite with ERC20 payments, multiple royalty receivers, claimable NFTs, and optimized for Base and SONEUM networks",
	"scripts": {
		"clean": "hardhat clean",
		"compile": "hardhat compile",
		"test": "hardhat test",
		"test:standard": "hardhat test test/KAMI721C.test.ts",
		"test:upgradeable": "hardhat test test/KAMI721CUpgradeable.test.ts",
		"coverage": "hardhat coverage",
		"lint": "solhint 'contracts/**/*.sol' && eslint . --ext .ts",
		"lint:fix": "solhint 'contracts/**/*.sol' --fix && eslint . --ext .ts --fix",
		"deploy:local": "hardhat run scripts/deploy.ts --network localhost",
		"deploy:goerli": "hardhat run scripts/deploy.ts --network goerli",
		"deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
		"deploy:mumbai": "hardhat run scripts/deploy.ts --network mumbai",
		"deploy:polygon": "hardhat run scripts/deploy.ts --network polygon",
		"deploy:mainnet": "hardhat run scripts/deploy.ts --network mainnet",
		"deploy:soneum": "hardhat run scripts/deploy.ts --network soneum",
		"deploy:minato": "hardhat run scripts/deploy.ts --network minato",
		"deploy:upgradeable:soneum": "hardhat run scripts/deploy_upgradeable_optimized.ts --network soneum",
		"deploy:upgradeable:minato": "hardhat run scripts/deploy_upgradeable_optimized.ts --network minato",
		"deploy:upgradeable:sepolia": "hardhat run scripts/deploy_upgradeable_optimized.ts --network sepolia",
		"deploy:upgradeable:mainnet": "hardhat run scripts/deploy_upgradeable_optimized.ts --network mainnet",
		"deploy:ac:minato": "hardhat run scripts/deploy_ac.ts --network minato",
		"deploy:ac:soneum": "hardhat run scripts/deploy_ac.ts --network soneum",
		"deploy:ac:upgradeable:minato": "hardhat run scripts/deploy_ac_upgradeable.ts --network minato",
		"deploy:ac:upgradeable:soneum": "hardhat run scripts/deploy_ac_upgradeable.ts --network soneum",
		"deploy:all:minato": "npm run deploy:minato && npm run deploy:upgradeable:minato && npm run deploy:ac:minato && npm run deploy:ac:upgradeable:minato",
		"deploy:all:soneum": "npm run deploy:soneum && npm run deploy:upgradeable:soneum && npm run deploy:ac:soneum && npm run deploy:ac:upgradeable:soneum",
		"node": "hardhat node",
		"size-check": "hardhat compile && find artifacts -name '*.json' -path '*/contracts/KAMI721*.json' -exec sh -c 'echo \"=== $1 ===\" && jq -r \".deployedBytecode\" \"$1\" | wc -c' _ {} \\;",
		"verify:minato": "hardhat verify --network minato",
		"verify:soneum": "hardhat verify --network soneum"
	},
	"devDependencies": {
		"@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
		"@nomicfoundation/hardhat-ethers": "^3.0.0",
		"@nomicfoundation/hardhat-network-helpers": "^1.0.0",
		"@nomicfoundation/hardhat-toolbox": "^4.0.0",
		"@nomicfoundation/hardhat-verify": "^2.0.0",
		"@nomiclabs/hardhat-solhint": "^3.0.0",
		"@typechain/ethers-v6": "^0.5.0",
		"@typechain/hardhat": "^9.0.0",
		"@types/mocha": "^10.0.10",
		"chai": "^4.3.7",
		"ethers": "^6.7.1",
		"hardhat": "^2.19.4",
		"hardhat-gas-reporter": "^1.0.9",
		"solhint": "^4.0.0",
		"solidity-coverage": "^0.8.5",
		"ts-node": "^10.9.2",
		"typechain": "^8.3.1",
		"typescript": "^5.8.2"
	},
	"dependencies": {
		"@openzeppelin/contracts": "^5.0.0",
		"@openzeppelin/contracts-upgradeable": "^5.0.0",
		"@openzeppelin/hardhat-upgrades": "^3.9.0",
		"dotenv": "^16.3.1"
	},
	"keywords": [
		"ethereum",
		"smart-contracts",
		"erc721",
		"nft",
		"royalties",
		"rental",
		"upgradeable",
		"base",
		"soneum",
		"optimized",
		"claimable",
		"airdrop",
		"batch-operations"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/KAMI-Github/KAMI-NFTs.git"
	},
	"author": "Paul Stinchcombe",
	"license": "MIT"
}
