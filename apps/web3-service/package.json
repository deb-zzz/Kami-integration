{
  "name": "kami-platform-web3-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Kami Platform Web3 Service handles the web3 related logic and communication for the Kami Platform",
  "scripts": {
    "dev": "next dev",
    "dev:web3-service": "next dev",
    "build": "pnpm exec prisma generate --schema=node_modules/kami-platform-v1-schema/prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "validate": "pnpm test:unit && pnpm build",
    "test:integration": "vitest run tests/integration",
    "test:kami721c": "vitest run tests/integration/kami721c.test.ts",
    "test:kami721ac": "vitest run tests/integration/kami721ac.test.ts",
    "deploy:libraries": "tsx scripts/deploy-libraries.ts",
    "deploy:simpleaccount": "tsx scripts/deploy-simpleaccount.ts",
    "deploy:contractdeployer": "tsx scripts/deploy-contractdeployer.ts",
    "setup:gasless": "tsx scripts/setup-gasless-infrastructure.ts",
    "find:libraries": "tsx scripts/find-library-addresses.ts",
    "grant:owner-role": "tsx scripts/grant-owner-role-to-simple-account.ts",
    "encrypt-key": "tsx scripts/encrypt-key.ts",
    "withdraw:simpleaccount": "tsx scripts/withdrawFromSimpleSAccount.ts",
    "sweep:all": "tsx scripts/sweepAll.ts",
    "test:checkout-product-20": "tsx scripts/test-checkout-product-20.ts",
    "test:set-total-supply-product-25": "tsx scripts/test-set-total-supply-product-25.ts",
    "test:buy-asset": "tsx scripts/test-buy-asset.ts",
    "test:two-account-kami721ac": "tsx scripts/test-two-account-kami721ac.ts",
    "test:two-account-kami721c": "tsx scripts/test-two-account-kami721c.ts",
    "debug:sell": "tsx scripts/debug-sell.ts",
    "docs:pdf": "node scripts/build-docs-pdf.mjs"
  },
  "prisma": {
    "schema": "node_modules/kami-platform-v1-schema/prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.971.0",
    "@aws-sdk/client-secrets-manager": "^3.968.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@openzeppelin/contracts-upgradeable": "^5.1.0",
    "@paulstinchcombe/gasless-nft-tx": "^0.17.6",
    "@prisma/client": "^6.16.0",
    "@types/ioredis": "^5.0.0",
    "axios": "^1.7.7",
    "dotenv": "^17.2.3",
    "ethers": "^6.15.0",
    "ioredis": "^5.4.1",
    "next": "14.2.12",
    "node-fetch": "^3.3.2",
    "prisma": "^6.16.0",
    "prisma-redis-middleware": "^4.8.0",
    "react": "^18",
    "react-dom": "^18",
    "viem": "^2.38.0",
    "kami-platform-v1-schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^8",
    "eslint-config-next": "14.2.12",
    "md-to-pdf": "^5.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3",
    "vitest": "^4.0.17"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bufferutil",
      "esbuild",
      "prisma",
      "protobufjs",
      "unrs-resolver",
      "utf-8-validate"
    ]
  }
}