{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "dist",
		"module": "ESNext",
		"target": "ESNext",
		"strict": true,
		"skipLibCheck": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},
		"jsx": "preserve",
		"noEmit": false
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
