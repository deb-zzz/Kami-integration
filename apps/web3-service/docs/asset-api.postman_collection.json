{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-4a70-8c9d-0e1f2a3b4c5d",
		"name": "KAMI Web3 Service - Asset API",
		"description": "Collection for the Asset API routes. Set `baseUrl` (e.g. `http://localhost:3000`) in collection or environment variables.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000"
		},
		{
			"key": "assetId",
			"value": "1"
		}
	],
	"item": [
		{
			"name": "List Assets",
			"_postman_id": "b2c3d4e5-f6a7-4b81-9d0e-1f2a3b4c5d6e",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/asset?page=1&perPage=10&sort=createdAt,desc",
					"host": ["{{baseUrl}}"],
					"path": ["api", "asset"],
					"query": [
						{
							"key": "page",
							"value": "1",
							"description": "Page number (default: 1)"
						},
						{
							"key": "perPage",
							"value": "10",
							"description": "Items per page (default: 10, max: 100)"
						},
						{
							"key": "sort",
							"value": "createdAt,desc",
							"description": "Multi-sort: field1,order1;field2,order2 (e.g. spotlight,desc;price,asc)"
						},
						{
							"key": "id",
							"value": "",
							"description": "Exact asset ID",
							"disabled": true
						},
						{
							"key": "walletAddress",
							"value": "",
							"description": "Owner wallet address",
							"disabled": true
						},
						{
							"key": "chainId",
							"value": "",
							"description": "Chain ID",
							"disabled": true
						},
						{
							"key": "collectionId",
							"value": "",
							"description": "Collection ID",
							"disabled": true
						},
						{
							"key": "productId",
							"value": "",
							"description": "Product ID",
							"disabled": true
						},
						{
							"key": "projectId",
							"value": "",
							"description": "Project ID",
							"disabled": true
						},
						{
							"key": "contractType",
							"value": "ERC721C",
							"description": "ERC721C | ERC721AC | ERC1155C",
							"disabled": true
						},
						{
							"key": "audience",
							"value": "Public",
							"description": "Public | Private | Whitelist | PublicBan | Prohibit",
							"disabled": true
						},
						{
							"key": "consumerAction",
							"value": "Buy",
							"description": "Buy | Subscribe | Rent | Claim | None",
							"disabled": true
						},
						{
							"key": "spotlight",
							"value": "true",
							"description": "true | false",
							"disabled": true
						},
						{
							"key": "canSubscribe",
							"value": "false",
							"description": "true | false",
							"disabled": true
						},
						{
							"key": "priceMin",
							"value": "",
							"description": "Minimum price",
							"disabled": true
						},
						{
							"key": "priceMax",
							"value": "",
							"description": "Maximum price",
							"disabled": true
						},
						{
							"key": "createdAtFrom",
							"value": "",
							"description": "ISO date (e.g. 2024-01-01T00:00:00Z)",
							"disabled": true
						},
						{
							"key": "createdAtTo",
							"value": "",
							"description": "ISO date",
							"disabled": true
						},
						{
							"key": "collectionName",
							"value": "",
							"description": "Collection name (contains)",
							"disabled": true
						},
						{
							"key": "projectName",
							"value": "",
							"description": "Project name (contains)",
							"disabled": true
						},
						{
							"key": "tag",
							"value": "",
							"description": "Tag (contains)",
							"disabled": true
						},
						{
							"key": "includeBlockchain",
							"value": "false",
							"description": "Include blockchain info in response",
							"disabled": true
						}
					]
				},
				"description": "List assets with optional filters, sorting, and pagination. Response includes product details when asset is linked to a product."
			}
		},
		{
			"name": "Get Asset by ID",
			"_postman_id": "c3d4e5f6-a7b8-4c92-0e1f-2a3b4c5d6e7f",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/asset/{{assetId}}?walletAddress=",
					"host": ["{{baseUrl}}"],
					"path": ["api", "asset", "{{assetId}}"],
					"query": [
						{
							"key": "walletAddress",
							"value": "",
							"description": "Optional. Viewer wallet for likedByMe and mention-level likedByMe"
						}
					]
				},
				"description": "Get a single asset by ID with full details: collection, project, product (when linked), owner, tags, likes, shares, and mentions (posts that reference this asset)."
			}
		},
		{
			"name": "Set Asset Price",
			"_postman_id": "d4e5f6a7-b8c9-4d03-1f2a-3b4c5d6e7f8a",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"price\": \"0.01\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/asset/{{assetId}}/setPrice",
					"host": ["{{baseUrl}}"],
					"path": ["api", "asset", "{{assetId}}", "setPrice"]
				},
				"description": "Set the sale price for an asset. Updates DB and on-chain for ERC721C/ERC721AC. Requires asset to have a collection; verifies on-chain ownership before updating."
			}
		},
		{
			"name": "Set Asset Audience",
			"_postman_id": "e5f6a7b8-c9d0-4e14-2a3b-4c5d6e7f8a9b",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"audience\": \"Public\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/asset/{{assetId}}/setAudience",
					"host": ["{{baseUrl}}"],
					"path": ["api", "asset", "{{assetId}}", "setAudience"]
				},
				"description": "Set the audience for an asset. Allowed values: Public, Private, Whitelist, PublicBan, Prohibit."
			}
		},
		{
			"name": "Set Asset Consumer Action",
			"_postman_id": "f6a7b8c9-d0e1-4f25-3b4c-5d6e7f8a9b0c",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"consumerAction\": \"Buy\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/asset/{{assetId}}/setConsumerAction",
					"host": ["{{baseUrl}}"],
					"path": ["api", "asset", "{{assetId}}", "setConsumerAction"]
				},
				"description": "Set the consumer action for an asset. Allowed values: Buy, Subscribe, Rent, Claim, None."
			}
		}
	]
}
