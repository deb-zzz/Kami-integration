# =============================================================================
# KAMI Platform Web3 Service - Environment Variables
# =============================================================================
# Copy this file to .env.local or .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/kami_platform

# -----------------------------------------------------------------------------
# Default Blockchain Configuration
# -----------------------------------------------------------------------------
# Default chain ID to use when chainId is not provided in requests or collections
# Must exist in the blockchain table. Format: hex string (e.g., "0x14a34" for Base Sepolia)
# This is used as a fallback when:
# - Creating collections without specifying chainId
# - Deploying/minting on collections without chainId set
DEFAULT_CHAIN_ID=0x14a34

# Entry Point address for SimpleAccount (ERC-4337). Optional override.
# Default: EntryPoint v0.7 (0x0000000071727De22E5E9d8BAf0edAc6f37da032, same on all chains).
# Only set this if you need to use a different EntryPoint (e.g. legacy v0.6).
# ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# When "true", execute() for operations (mint, setPrice, etc.) is sent via EntryPoint.handleOps (UserOperation)
# instead of direct Platform Funding EOA → SimpleAccount.execute(). Use when the SimpleAccount only allows
# the EntryPoint (or owner) to call execute(). When true, the SimpleAccount must have an EntryPoint deposit
# (call EntryPoint.depositTo(simpleAccountAddress) with ETH); gas is paid from that deposit, not from native balance.
# USE_ENTRY_POINT_FOR_EXECUTE=false

# When "true", deployment is sent via EntryPoint.handleOps (UserOp) instead of direct Platform Funding EOA → SimpleAccount.execute().
# Use when the SimpleAccount reverts with "Account: not Owner or EntryPoint" on deploy. Same EntryPoint deposit requirement as above.
# USE_ENTRYPOINT_FOR_DEPLOYMENT=false

# Optional: fund the SimpleAccount with ETH after deploy (e.g. "0.005"). Used by deploy-simpleaccount.ts when set.
# FUND_SIMPLE_ACCOUNT_ETH=

# Optional: fund the SimpleAccount's EntryPoint deposit (for EntryPoint path). Platform Funding EOA sends ETH via
# EntryPoint.depositTo(simpleAccountAddress). Used by deploy-simpleaccount.ts and setup-gasless-infrastructure.ts when set (e.g. "0.01").
# FUND_ENTRYPOINT_DEPOSIT_ETH=

# -----------------------------------------------------------------------------
# Secrets and Encryption (Required for gasless operations)
# -----------------------------------------------------------------------------
# Required: 64-character hex string (32 bytes) used to decrypt private keys
# stored in the database (platform.platformFundingWalletPrivateKey, account.pk).
# Generate with: openssl rand -hex 32
# See also: scripts/encrypt-key.ts
ENCRYPTION_KEY=

# Optional: Salt for deterministic wallet generation (EthereumAccountService).
# Default used if not set.
# ETHEREUM_SALT=

# Optional: AWS Secrets Manager secret name for platform private key fallback
# when key is not in database. See src/app/utils/secrets.ts.
# AWS_SECRET_NAME=

# -----------------------------------------------------------------------------
# Filebase (IPFS) - Required for POST /api/ipfs/upload
# -----------------------------------------------------------------------------
# Filebase is S3-compatible; uploads return IPFS CIDs. Set these to enable
# the IPFS upload endpoint.
# FILEBASE_ACCESS_KEY=
# FILEBASE_SECRET_KEY=
# FILEBASE_BUCKET=

# -----------------------------------------------------------------------------
# Redis Configuration (Optional - Currently Commented Out)
# -----------------------------------------------------------------------------
# Redis connection string for caching (if enabled)
# Format: redis://user:password@host:port
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Next.js Configuration
# -----------------------------------------------------------------------------
# Node environment: development, production, or test
NODE_ENV=development

# Next.js public variables (exposed to browser)
# NEXT_PUBLIC_TW_CLIENT_ID=

# =============================================================================
# Database Configuration (Required)
# =============================================================================
# All blockchain-related configuration is stored in the database, not in environment variables.
# You must configure the following tables after setting up your database:
#
# 1. blockchain table:
#    - chainId: Blockchain chain ID (hex string, e.g., '0x14a34')
#    - name: Human-readable blockchain name (e.g., 'Base Sepolia')
#    - rpcUrl: RPC endpoint URL (e.g., 'https://sepolia.base.org')
#    - logoUrl: Optional logo URL
#
# 2. platform table:
#    - chainId: Reference to blockchain.chainId
#    - simpleAccountAddress: SimpleAccount address for gasless operations
#    - contractDeployerAddress: Contract deployer address
#    - platformFundingWalletAddress: Platform Funding EOA address (holds gas, signs; from platformPrivateKey)
#    - platformFundingWalletPrivateKey: Platform Funding EOA private key (encrypted; funds gas, signs)
#    - platformAddress: Fee-recipient address (receives protocol fees)
#    - kamiNFTCoreLibraryAddress: KAMI NFT Core library address
#    - kamiPlatformLibraryAddress: KAMI Platform library address
#    - kamiRoyaltyLibraryAddress: KAMI Royalty library address
#    - kamiRentalLibraryAddress: KAMI Rental library address
#    - kamiTransferLibraryAddress: KAMI Transfer library address
#
# 3. payment_token table:
#    - chainId: Reference to blockchain.chainId
#    - contractAddress: Payment token contract address (e.g., USDC)
#    - name: Token name (e.g., 'USD Coin')
#    - symbol: Token symbol (e.g., 'USDC')
#    - decimals: Token decimals (e.g., 6 for USDC)
#    - logoUrl: Optional logo URL
#
# 4. account table:
#    - walletAddress: User wallet address
#    - chainId: Optional chain ID (for multi-chain accounts)
#    - pk: Encrypted private key
#    - email: Optional email
#    - phone: Optional phone number
#
# Note: Use the setup scripts to populate these tables:
#   tsx scripts/setup-gasless-infrastructure.ts <chainId> <privateKey>
#
# =============================================================================
# Quick Start
# =============================================================================
# 1. Copy this file: cp env.example .env.local
# 2. Fill in DATABASE_URL with your PostgreSQL connection string
# 3. Set ENCRYPTION_KEY (generate with: openssl rand -hex 32) for decrypting DB-stored keys
# 4. Set DEFAULT_CHAIN_ID to your preferred default blockchain (must exist in blockchain table)
# 5. Run database migrations: npx prisma migrate deploy
# 6. Set up blockchain configuration in database:
#    - Add blockchain entries with RPC URLs
#    - Deploy gasless infrastructure: tsx scripts/setup-gasless-infrastructure.ts <chainId> <privateKey>
#    - This will populate the platform table with all required addresses
#    - Add payment token entries for each blockchain
# 7. Start development server: pnpm dev
#
# =============================================================================
# Important Notes
# =============================================================================
# - All blockchain configuration (RPC URLs, platform addresses, library addresses,
#   payment tokens, private keys) should be stored in the database, NOT in environment variables
# - Environment variables are only for:
#   * Database connection (DATABASE_URL)
#   * Default fallback chain ID (DEFAULT_CHAIN_ID)
#   * Secrets: ENCRYPTION_KEY (required to decrypt DB-stored private keys)
#   * Optional: ETHEREUM_SALT (deterministic wallets), AWS_SECRET_NAME (key fallback)
#   * Optional: FILEBASE_* (for POST /api/ipfs/upload), REDIS_URL (caching)
#   * Deployment script configuration (ENTRY_POINT_ADDRESS, USE_ENTRY_POINT_FOR_EXECUTE, USE_ENTRYPOINT_FOR_DEPLOYMENT, FUND_SIMPLE_ACCOUNT_ETH, FUND_ENTRYPOINT_DEPOSIT_ETH)
# - The DEFAULT_CHAIN_ID must exist in the blockchain table before use
# - Use the setup scripts to properly configure blockchain infrastructure
#
# =============================================================================

