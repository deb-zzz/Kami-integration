{
	"compilerOptions": {
		"target": "ES2017",
		"module": "commonjs",
		"lib": ["ES2017", "DOM"],
		"declaration": true,
		"declarationMap": true,
		"outDir": "./dist-cjs",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"jsx": "react"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "dist-cjs", "dist-es"]
}

