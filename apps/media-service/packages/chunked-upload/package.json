{
	"name": "@paulstinchcombe/chunked-upload",
	"version": "0.1.6",
	"description": "React hook for chunked file uploads with progress tracking and retry logic",
	"main": "dist/index.cjs.js",
	"module": "dist/index.esm.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.esm.js",
			"require": "./dist/index.cjs.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "npm run clean && tsc && tsc --project tsconfig.esm.json && node scripts/rename-outputs.js",
		"prepublishOnly": "npm run build",
		"clean": "rm -rf dist dist-cjs dist-es"
	},
	"keywords": [
		"react",
		"hook",
		"upload",
		"chunked",
		"file-upload",
		"progress",
		"typescript",
		"kamiunlimited",
		"chunked-upload",
		"kami-upload",
		"kami"
	],
	"author": "Paul Stinchcombe",
	"license": "MIT",
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@types/react": "^18.0.0",
		"typescript": "^5.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/paulstinchcombe/chunked-upload.git"
	}
}
